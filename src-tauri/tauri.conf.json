{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "spec-board",
	"version": "0.1.0",
	"identifier": "io.github.dio0550.specboard",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:4000",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "spec-board",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost ws://localhost:4001"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
